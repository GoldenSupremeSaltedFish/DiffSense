{
  "rulesets": {
    "default": ["rules/"],
    "pro": ["rules/", "pro-rules/"],
    "pro_only": ["pro-rules/"],
    "java_only": ["rules/", "pro-rules/java/"],
    "go_only": ["rules/", "pro-rules/go/"],
    "python_only": ["rules/", "pro-rules/python/"],
    "multilang": ["rules/", "pro-rules/java/", "pro-rules/go/", "pro-rules/python/"]
  },
  "parsers": {
    "enabled": ["java", "go", "python"],
    "java": {
      "class": "diffsense.parsers.java_parser.JavaParser"
    },
    "go": {
      "class": "diffsense.parsers.go_parser.GoParser"
    },
    "python": {
      "class": "diffsense.parsers.python_parser.PythonParser"
    }
  }
}